# Runtime profile
CERUL_ENV=development

# Private runtime / secrets
# Copy to .env for local development.
# Keep deployment-only secrets in a separate .env.production file.
# Database
DATABASE_URL=

# Auth
BETTER_AUTH_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Console admin access
ADMIN_CONSOLE_EMAILS=
BOOTSTRAP_ADMIN_SECRET=

# OpenAI (reranker default — pointwise, 1 call per candidate; also used for transcription)
OPENAI_API_KEY=
OPENAI_TRANSCRIBE_MODEL=gpt-4o-transcribe

# Cohere (optional — batch reranker, 1 API call for all candidates, recommended for production)
# To activate: set rerank_backend: cohere in config/base.yaml (or CERUL__KNOWLEDGE__RERANK_BACKEND=cohere)
COHERE_API_KEY=

# Gemini
GEMINI_API_KEY=

# Content APIs
PEXELS_API_KEY=
PIXABAY_API_KEY=
YOUTUBE_API_KEY=
YTDLP_BIN=yt-dlp
YTDLP_PROXY=http://spois78ei0:4XwmH4y+xIEbu1hg6n@gate.decodo.com:10001

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Provider-managed runtime values
STRIPE_PRO_PRICE_ID=

# Optional overrides for values that normally live in config/*.yaml.
# Leave blank unless you need an env-specific override.
API_BASE_URL=
WEB_BASE_URL=
NEXT_PUBLIC_API_BASE_URL=
NEXT_PUBLIC_SITE_URL=
MMR_LAMBDA=
SCENE_THRESHOLD=
KNOWLEDGE_RERANK_TOP_N=
CLIP_SCORE_THRESHOLD=
RERANK_PROMPT=
