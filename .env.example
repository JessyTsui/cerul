# Runtime
CERUL_ENV=development
API_BASE_URL=http://localhost:8787
WEB_BASE_URL=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8787
NEXT_PUBLIC_SITE_URL=http://localhost:3000
DEMO_MODE=true

# Core (shared with backend)
DATABASE_URL=
BETTER_AUTH_SECRET=
ADMIN_CONSOLE_EMAILS=
BOOTSTRAP_ADMIN_SECRET=

# OAuth providers (optional)
# Google One Tap uses the same Google OAuth client.
# Make sure your Google app includes the frontend origin in Authorized JavaScript origins
# (for example: http://localhost:3000 and https://cerul.ai).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Transactional email (optional)
RESEND_API_KEY=
EMAIL_FROM="Cerul <noreply@cerul.ai>"
