# Runtime profile
CERUL_ENV=development

# Core runtime
DATABASE_URL=
BETTER_AUTH_SECRET=
ADMIN_CONSOLE_EMAILS=
BOOTSTRAP_ADMIN_SECRET=

# Model providers
OPENAI_API_KEY=
GEMINI_API_KEY=
COHERE_API_KEY=

# Embedding backend (gemini | openai_compatible)
EMBEDDING_BACKEND=gemini
# EMBEDDING_OPENAI_BASE_URL=https://your-gpu-server:8080/v1
# EMBEDDING_OPENAI_API_KEY=
# EMBEDDING_OPENAI_MODEL=qwen3-vl-embedding-2b
# EMBEDDING_DIMENSION=2048

# ASR (speech-to-text)
ASR_BASE_URL=https://api.groq.com/openai/v1
ASR_MODEL=whisper-large-v3-turbo
ASR_API_KEY=

# Cloudflare R2 keyframe storage
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=cerul-cdn
R2_PUBLIC_URL=https://cdn.cerul.ai

# Content APIs
YOUTUBE_API_KEY=
PEXELS_API_KEY=
PIXABAY_API_KEY=

# OAuth providers (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Stripe billing (optional)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=

# Worker tuning
WORKER_CONCURRENCY=2

# Proxy (optional, for local dev in China etc.)
YTDLP_PROXY=
HTTPS_PROXY=
