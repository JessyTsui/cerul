# Runtime profile
CERUL_ENV=development

# Recommended local development variables
DATABASE_URL=
BETTER_AUTH_SECRET=
ADMIN_CONSOLE_EMAILS=
OPENAI_API_KEY=
GEMINI_API_KEY=
YOUTUBE_API_KEY=
PEXELS_API_KEY=
PIXABAY_API_KEY=
YTDLP_PROXY=

# Optional parameters you can enable when needed

# Optional embedding backend selection.
# Default stays Gemini; switch to openai_compatible only when you have a compatible
# /v1/embeddings service ready (for example, self-hosted Qwen via vLLM).
EMBEDDING_BACKEND=gemini
# EMBEDDING_DIMENSION=3072

# Optional worker runtime tuning
WORKER_CONCURRENCY=2

# Optional Cloudflare R2 keyframe storage
# Public-facing URLs should use your custom CDN domain, not the raw R2 endpoint.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=cerul-cdn
R2_PUBLIC_URL=https://cdn.example.com

# Optional ASR overrides for OpenAI-compatible transcription backends.
# Leave blank to reuse OPENAI_API_KEY + config/base.yaml defaults.
# Example (Groq):
ASR_BASE_URL=https://api.groq.com/openai/v1
ASR_MODEL=whisper-large-v3-turbo
ASR_API_KEY=
# ASR_PROXY=http://proxy.example:8080
# ASR_BASE_URL=
# ASR_MODEL=whisper-1

# Optional OpenAI-compatible embedding backend overrides.
# Example:
# EMBEDDING_BACKEND=openai_compatible
# EMBEDDING_OPENAI_BASE_URL=https://your-gpu-server:8080/v1
# EMBEDDING_OPENAI_API_KEY=
# EMBEDDING_OPENAI_MODEL=qwen3-vl-embedding-2b

# Optional auth providers
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Optional admin / billing / search providers
BOOTSTRAP_ADMIN_SECRET=
COHERE_API_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=
