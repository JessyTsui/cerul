# Copy this file to .env on the VPS before running docker compose.

# Runtime
CERUL_ENV=production

# Required
DATABASE_URL=postgresql://user:pass@your-neon-host/cerul?sslmode=require

# Model providers
GEMINI_API_KEY=
OPENAI_API_KEY=

# ASR
ASR_BASE_URL=https://api.groq.com/openai/v1
ASR_MODEL=whisper-large-v3-turbo
ASR_API_KEY=

# Cloudflare R2 (frame uploads)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=cerul-cdn
R2_PUBLIC_URL=https://cdn.cerul.ai

# YouTube
YOUTUBE_API_KEY=

# Content APIs (optional for broll jobs)
PEXELS_API_KEY=
PIXABAY_API_KEY=

# Worker tuning
WORKER_CONCURRENCY=6
LOG_LEVEL=INFO

# yt-dlp
YTDLP_VERSION=2025.06.09
YTDLP_PROXY=
YTDLP_COOKIES_FILE=/app/cookies.txt
